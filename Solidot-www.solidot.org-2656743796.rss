yLiteView&quot;:false}},&quot;ctrl&quot;:&quot;Follow&quot;,&quot;entityLabel&quot;:&quot;GOOG&quot;,&quot;iconOnly&quot;:true,&quot;position&quot;:1}" data-wf-boundary="caas-xray-entity-follow-button-boundary-container" data-wf-cache="0" data-wf-credentials="include" data-wf-session-retry-count="1" data-wf-target=".caas-xray-entity-follow-button-wf-container" data-wf-trigger="onLoad" data-wf-url="https://embed.fireplace.yahoo.com/_rcv/remote"><div><span><span><svg viewBox="0 0 24 24"><path d="M8.48186998,8.32925207 L1.96976839,8.54025207 C1.08316301,8.56825207 0.670346742,9.65725207 1.31106157,10.2722521 L6.29784205,15.0522521 L4.88447112,21.1762521 C4.68555965,22.3152521 5.65112989,22.6662521 6.14590968,22.4302521 L12.0132982,19.2092521 L17.7987232,22.4302521 C18.2785097,22.6582521 19.2620719,22.3332521 19.0591622,21.1762521 L17.7297539,15.0522521 L22.6885469,10.2722521 C23.3302613,9.65725207 22.9164454,8.56825207 22.0308396,8.54025207 L15.5477251,8.32925207 L12.9308898,2.10925207 C12.5840442,1.29525207 11.4355554,1.29725207 11.0917084,2.11325207 L8.48186998,8.32925207 Z M15.5377296,14.3792521 L16.6472357,19.4902521 L12.0202951,16.9142521 L7.32638427,19.4912521 L8.5038602,14.3872521 L4.41767888,10.4762521 L9.82627162,10.2972521 L12.0142978,5.08125207 L14.2033235,10.2962521 L19.5969229,10.4762521 L15.5377296,14.3792521 Z"></path></svg></span></span></div></div></div></div></li></ul><button aria-label="Show previous cards" data-ylk="g:e3cd52e5-d7ed-31cb-b9a1-f89d41921909;itc:1;sec:pill;elm:pill-arrow;slk:previous"><span><svg viewBox="0 0 20 20"><path d="M9.00177132 10.0007114l4.08829038-4.02939921c.3144838-.31076732.3194363-.83061107-.0024763-1.1478866-.3252143-.32052964-.8444016-.31890259-1.1646634-.00244058L6.66666667 10.0007114l5.25790623 5.1813535c.3153093.3107673.8427507.3156485 1.1646633-.0024406.3243889-.3197161.3235635-.8314246.0024763-1.1478866l-4.08994118-4.0310263z"></path></svg></span></button><button aria-label="Show next cards" data-ylk="g:e3cd52e5-d7ed-31cb-b9a1-f89d41921909;itc:1;sec:pill;elm:pill-arrow;slk:next"><span><svg viewBox="0 0 20 20"><path d="M9.00177132 10.0007114l4.08829038-4.02939921c.3144838-.31076732.3194363-.83061107-.0024763-1.1478866-.3252143-.32052964-.8444016-.31890259-1.1646634-.00244058L6.66666667 10.0007114l5.25790623 5.1813535c.3153093.3107673.8427507.3156485 1.1646633-.0024406.3243889-.3197161.3235635-.8314246.0024763-1.1478866l-4.08994118-4.0310263z" transform="rotate(180, 10, 10)"></path></svg></span></button></div></div></div><div><p>(Bloomberg) -- The use of YouTube videos to train OpenAI’s text-to-video generator would be an infraction of the platform's terms of service, YouTube Chief Executive Officer Neal Mohan said.</p><p>Most Read from Bloomberg</p><ul><li><p><a href="https://www.bloomberg.com/news/articles/2024-04-05/saudis-scale-back-ambition-for-1-5-trillion-desert-project-neom?utm_campaign=bn&amp;utm_medium=distro&amp;utm_source=yahooUS" target="_blank" data-ylk="slk:Saudis Scale Back Ambition for $1.5 Trillion Desert Project Neom;elm:context_link;itc:0;sec:content-canvas">Saudis Scale Back Ambition for $1.5 Trillion Desert Project Neom</a></p></li><li><p><a href="https://www.bloomberg.com/news/articles/2024-04-05/turkey-joins-nato-allies-in-suspending-europe-arms-treaty?utm_campaign=bn&amp;utm_medium=distro&amp;utm_source=yahooUS" target="_blank" data-ylk="slk:Turkey Joins NATO Allies in Suspending Europe Arms Treaty;elm:context_link;itc:0;sec:content-canvas">Turkey Joins NATO Allies in Suspending Europe Arms Treaty</a></p></li><li><p><a href="https://www.bloomberg.com/news/articles/2024-04-05/tremors-felt-throughout-nyc-region-in-4-8-magnitude-quake?utm_campaign=bn&amp;utm_medium=distro&amp;utm_source=yahooUS" target="_blank" data-ylk="slk:NY Area Rattled by 4.8 Magnitude Quake, Followed by Aftershock;elm:context_link;itc:0;sec:content-canvas">NY Area Rattled by 4.8 Magnitude Quake, Followed by Aftershock</a></p></li><li><p><a href="https://www.bloomberg.com/news/articles/2024-04-05/iran-tells-us-to-step-aside-as-it-readies-response-to-israel?utm_campaign=bn&amp;utm_medium=distro&amp;utm_source=yahooUS" target="_blank" data-ylk="slk:Iran Tells US to Step Aside as It Readies Response to Israel;elm:context_link;itc:0;sec:content-canvas">Iran Tells US to Step Aside as It Readies Response to Israel</a></p></li><li><p><a href="https://www.bloomberg.com/news/articles/2024-04-05/zuckerberg-is-world-s-third-richest-person-passing-his-arch-rival-elon-musk?utm_campaign=bn&amp;utm_medium=distro&amp;utm_source=yahooUS" target="_blank" data-ylk="slk:Mark Zuckerberg’s Wealth Exceeds Elon Musk’s for the First Time Since 2020;elm:context_link;itc:0;sec:content-canvas">Mark Zuckerberg’s Wealth Exceeds Elon Musk’s for the First Time Since 2020</a></p></li></ul><p>In his first public remarks on the topic, Mohan said he had no firsthand knowledge of whether OpenAI had, in fact, used YouTube videos to refine its artificial intelligence-powered video creation tool, called Sora. But if that were the case, it would be a “clear violation” of YouTube’s terms of use, he said.</p><div><div data-wf-benji-page-context="{&quot;pageUrl&quot;:&quot;https://ca.finance.yahoo.com/news/youtube-says-openai-training-sora-185454534.html&quot;,&quot;spaceid&quot;:&quot;1184585452&quot;,&quot;site&quot;:&quot;finance&quot;,&quot;hashtag&quot;:&quot;business&quot;,&quot;lmsid&quot;:&quot;a097000000F1kX6AAJ&quot;,&quot;lpstaid&quot;:&quot;e3cd52e5-d7ed-31cb-b9a1-f89d41921909&quot;,&quot;pct&quot;:&quot;story&quot;}" data-wf-benji-wafer-config="{}" data-wf-benji-config="{&quot;positions&quot;:{&quot;INARTICLE-e3cd52e5-d7ed-31cb-b9a1-f89d419219091712406122048&quot;:{&quot;id&quot;:&quot;INARTICLE-e3cd52e5-d7ed-31cb-b9a1-f89d419219091712406122048&quot;,&quot;path&quot;:&quot;/22888152279/${REGION}/yfin/ros/dt/${REGION}_yfin_ros_dt_mid_center&quot;,&quot;region&quot;:&quot;index&quot;,&quot;size&quot;:&quot;fluid&quot;,&quot;kvs&quot;:{&quot;loc&quot;:&quot;mid_center&quot;},&quot;disableRefresh&quot;:true}}}" data-wf-trigger="onLoad" data-wf-margin="100 0"><div>ADVERTISEMENT</div></div></div><p>“From a creator’s perspective, when a creator uploads their hard work to our platform, they have certain expectations,” Mohan said earlier this week in an interview with Emily Chang, host of Bloomberg Originals. “One of those expectations is that the terms of service is going to be abided by. It does not allow for things like transcripts or video bits to be downloaded, and that is a clear violation of our terms of service. Those are the rules of the road in terms of content on our platform.”</p><p>There has been much public debate over what material OpenAI uses to train the AI models underlying popular content creation products such as ChatGPT and DALL-E. Sora and other generative AI tools work by sucking up all sorts of content from around the web and using that data as the foundation from which the tools can generate new content, including videos, photos, narrative text and more. As companies like OpenAI, Google and others race to develop more powerful artificial intelligence, they are looking to source as much content as possible to train their AI models to get better quality results. Google and YouTube are units of Alphabet Inc.</p><div><button data-ylk="elm:readmore;slk:Story continues">Story continues</button></div><p>OpenAI, which is backed by Microsoft Corp., didn’t immediately respond to a request for comment. OpenAI Chief Technology Officer Mira Murati said in an interview with the Wall Street Journal last month that she wasn’t sure whether Sora was trained on user-generated videos from YouTube, Facebook and Instagram. The Journal reported this week that OpenAI has discussed training its next-generation large language model, GPT-5, on transcriptions of public YouTube videos, citing people familiar with the matter.</p><p>Mohan said Google adheres to YouTube’s individual contracts with creators before deciding whether to use videos from the platform in training the company’s own powerful AI model, Gemini.</p><p>“Lots of creators have different sorts of licensing contracts in terms of their content on our platform,” Mohan said. Though “some portion of that YouTube corpus maybe being used” to train models like Gemini, Google and YouTube ensure that using the videos as training data for Google’s AI is “in concert with whatever the terms of service or the contract that that creator has signed” beforehand, he said.</p><p>(Updates with details on timing of Mohan interview in third paragraph.)</p><p>Most Read from Bloomberg Businessweek</p><ul><li><p><a href="https://www.bloomberg.com/news/features/2024-04-03/hertz-htz-selling-electric-cars-ends-its-failed-tesla-bet?utm_campaign=bw&amp;utm_medium=distro&amp;utm_source=yahooUS" target="_blank" data-ylk="slk:How Hertz’s Bet on Teslas Went Horribly Sideways;elm:context_link;itc:0;sec:content-canvas">How Hertz’s Bet on Teslas Went Horribly Sideways</a></p></li><li><p><a href="https://www.bloomberg.com/news/articles/2024-04-04/fixing-boeing-s-broken-culture-starts-with-a-new-plane?utm_campaign=bw&amp;utm_medium=distro&amp;utm_source=yahooUS" target="_blank" data-ylk="slk:Fixing Boeing’s Broken Culture Starts With a New Plane;elm:context_link;itc:0;sec:content-canvas">Fixing Boeing’s Broken Culture Starts With a New Plane</a></p></li><li><p><a href="https://www.bloomberg.com/news/articles/2024-04-02/podcast-elon-musk-s-x-has-a-pornography-problem?utm_campaign=bw&amp;utm_medium=distro&amp;utm_source=yahooUS" target="_blank" data-ylk="slk:Elon Musk’s X Has a Porn Problem;elm:context_link;itc:0;sec:content-canvas">Elon Musk’s X Has a Porn Problem</a></p></li><li><p><a href="https://www.bloomberg.com/news/features/2024-04-03/is-bluey-ending-disney-s-worried-biggest-kids-show-ever-is-at-risk?utm_campaign=bw&amp;utm_medium=distro&amp;utm_source=yahooUS" target="_blank" data-ylk="slk:How Bluey Became a $2 Billion Smash Hit—With an Uncertain Future;elm:context_link;itc:0;s